# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins. Set to your Vercel domain in production.
# NEVER use * in production.
CORS_ORIGINS=http://localhost:3000

# ── Limits ───────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
MAX_AUDIO_SECONDS=15.0

# ── App ──────────────────────────────────────────────────────
APP_VERSION=0.2.0
ENVIRONMENT=development
